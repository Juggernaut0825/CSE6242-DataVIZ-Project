# ============================================
# GauzRag 配置文件示例
# 
# 使用方法：
# 1. 复制此文件为 .env
# 2. 填入你的真实 API 密钥和配置
# ============================================

# ============================================
# MySQL 数据库配置
# ============================================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here
MYSQL_DB=gauzgraph
MYSQL_TABLE=facts

# ============================================
# LLM 配置
# ============================================
GAUZ_LLM_PROVIDER=openai
GAUZ_LLM_API_BASE=https://api.openai.com/v1
GAUZ_LLM_API_KEY=sk-your-api-key-here
GAUZ_LLM_MODEL=gpt-4o-mini
GAUZ_LLM_MAX_TOKENS=
GAUZ_LLM_TEMPERATURE=0.3

# ============================================
# Embedding 配置（阿里云百炼）
# ============================================
DASHSCOPE_API_KEY=sk-your-dashscope-key-here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4

# ============================================
# Neo4j 图数据库配置
# ============================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password

# ============================================
# Qdrant 向量数据库配置
# ============================================
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# ============================================
# API 服务配置
# ============================================
API_HOST=0.0.0.0
API_PORT=1234
API_RELOAD=True

# ============================================
# 可选配置
# ============================================

# Azure OpenAI (可选)
# GAUZ_AZURE_ENDPOINT=
# GAUZ_AZURE_DEPLOYMENT=
# GAUZ_AZURE_API_VERSION=

# 其他 LLM 提供商示例
# X.AI Grok
# GAUZ_LLM_API_BASE=https://api.x.ai/v1
# GAUZ_LLM_MODEL=grok-beta

# OpenRouter
# GAUZ_LLM_API_BASE=https://openrouter.ai/api/v1
# GAUZ_LLM_MODEL=x-ai/grok-4.1-fast
