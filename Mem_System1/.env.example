# Legacy GauzRag env example.
# Primary runtime has moved to `paper_app/backend/.env`.
# Keep this file only if you still want to experiment with old Mem_System1 code.

GAUZ_LLM_PROVIDER=openai
GAUZ_LLM_API_BASE=https://openrouter.ai/api/v1
GAUZ_LLM_API_KEY=
GAUZ_LLM_MODEL=openai/gpt-4o-mini
GAUZ_LLM_TEMPERATURE=0.3

DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4

NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=papermemneo4j
