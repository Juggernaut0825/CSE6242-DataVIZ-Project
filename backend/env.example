# Chat / reasoner: key from https://openrouter.ai/keys (401 User not found = bad or revoked key)
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-4o-mini
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=256
EMBEDDING_BATCH_SIZE=96
CORS_ALLOW_ORIGINS=*
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=papermemneo4j
NEO4J_REQUIRED=false

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DATABASE=papermem
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20
POSTGRES_ECHO=false

RETRIEVAL_TOP_K=6
RETRIEVAL_LEXICAL_TOP_K=10
RETRIEVAL_GRAPH_UNIT_LIMIT=8
RETRIEVAL_ADJACENT_CHUNK_RADIUS=1
ANSWER_CONTEXT_CHAR_BUDGET=14000
ANSWER_EVIDENCE_CHARS_PER_UNIT=1600
GRAPH_EXPANSION_HOPS=2
CHUNK_SIZE=1600
CHUNK_OVERLAP=150
SEMANTIC_ZOOM_DEFAULT=macro

# Ingestion speed controls.
# Every chunk still gets graph nodes; unsampled chunks use local semantic fallback.
# "mmr" selects LLM-labeled chunks by content salience + embedding diversity.
SEMANTIC_LLM_ENABLED=true
SEMANTIC_LLM_FILE_SAMPLE_RATIO=0.20
SEMANTIC_LLM_FILE_SAMPLE_MIN=8
SEMANTIC_LLM_FILE_SAMPLE_MAX=0
SEMANTIC_LLM_SELECTION_STRATEGY=mmr
SEMANTIC_LLM_CONVERSATION_SAMPLE_LIMIT=4
SEMANTIC_LLM_TIMEOUT_SECONDS=8
SEMANTIC_LLM_CONCURRENCY=4
RELATION_LINK_TOP_K=2
