# Optional overrides. By default this also loads backend/.env.
EVAL_OPENAI_API_KEY=
EVAL_OPENAI_BASE_URL=https://api.openai.com/v1
EVAL_QUESTION_MODEL=gpt-5.4
EVAL_JUDGE_MODEL=gpt-5.4
EVAL_RAG_MODEL=gpt-4o-mini
EVAL_BARE_MODEL=gpt-4o-mini
EVAL_EMBEDDING_MODEL=text-embedding-3-small
EVAL_EMBEDDING_DIMENSIONS=256
EVAL_PAPERMEM_API_BASE=http://127.0.0.1:8000

# Retrieval baseline knobs.
EVAL_RAG_TOP_K=8
EVAL_RAG_CHUNK_CHARS=1800
EVAL_RAG_CHUNK_OVERLAP=250
EVAL_RAG_MAX_CONTEXT_CHARS=14000
EVAL_PAPER_SAMPLE_CHARS=18000

